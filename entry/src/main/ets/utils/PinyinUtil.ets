// 兼容导出：保持旧的函数名供 GameViewModel.ets 和 GamePage.ets 使用
export function getPinyinInitials(str: string): string {
  return getInitialLetters(str);
}

/**
 * 获取字符串的首字母（大写）
 * @param str 输入字符串
 * @returns 首字母字符串（如："Y X Y Y"）
 */
export function getInitialLetters(str: string): string {
  const chars = str.split('');
  const initials = chars.map(char => {
    return PINYIN_MAP[char] || '?';
  });
  return initials.join(' ');
}

/**
 * 从完整拼音字段提取首字母。优先用于题库数据，避免多音字和映射表误差。
 * @param pinyin 空格分隔的拼音，如 "yī xīn yī yì"
 * @returns 首字母数组，如 ["Y", "X", "Y", "Y"]
 */
export function getInitialLettersFromPinyin(pinyin: string): string[] {
  if (!pinyin) {
    return [];
  }

  const parts = pinyin.split(/\s+/);
  const result: string[] = [];
  parts.forEach(part => {
    const normalized = normalizePinyinToneMarks(part).replace(/[^A-Za-z]/g, '');
    if (normalized.length > 0) {
      result.push(normalized[0].toUpperCase());
    }
  });
  return result;
}

function normalizePinyinToneMarks(value: string): string {
  return value
    .replace(/[āáǎà]/g, 'a')
    .replace(/[ēéěè]/g, 'e')
    .replace(/[īíǐì]/g, 'i')
    .replace(/[ōóǒò]/g, 'o')
    .replace(/[ūúǔù]/g, 'u')
    .replace(/[ǖǘǚǜü]/g, 'v')
    .replace(/[ĀÁǍÀ]/g, 'A')
    .replace(/[ĒÉĚÈ]/g, 'E')
    .replace(/[ĪÍǏÌ]/g, 'I')
    .replace(/[ŌÓǑÒ]/g, 'O')
    .replace(/[ŪÚǓÙ]/g, 'U')
    .replace(/[ǕǗǙǛÜ]/g, 'V');
}

function getInitialLettersByWordAndPinyin(word: string, pinyin: string): string[] {
  const chars = word.split('');
  const fromPinyin = getInitialLettersFromPinyin(pinyin);
  const fallback = getInitialLetters(word).split(' ');
  const result: string[] = [];

  for (let i = 0; i < chars.length; i++) {
    result.push(fromPinyin[i] || fallback[i] || '?');
  }
  return result;
}

/**
 * 根据已揭示的汉字数量生成提示文本
 * 提示逻辑：先显示拼音首字母，每用一次提示多揭示一个汉字
 * @param word 完整成语，如 "龙飞凤舞"
 * @param revealedCount 已揭示的汉字数量（0=只显示拼音，1=揭示第1个字，以此类推）
 * @returns 提示文本，如 "L F F W"、"龙 F F W"、"龙 飞 F W"
 */
export function generatePinyinHint(word: string, revealedCount: number): string {
  const initials = getInitialLetters(word).split(' ');
  const chars = word.split('');
  const result: string[] = [];

  for (let i = 0; i < chars.length; i++) {
    if (i < revealedCount) {
      // 已揭示的汉字，直接显示汉字
      result.push(chars[i]);
    } else {
      // 未揭示的位置，显示拼音首字母
      result.push(initials[i] || '?');
    }
  }

  return result.join(' ');
}

/**
 * 根据题库拼音字段生成逐字提示。
 * @param word 完整成语
 * @param pinyin 题库中的完整拼音
 * @param revealedCount 已揭示的汉字数量
 * @returns 提示文本
 */
export function generatePinyinHintFromPinyin(word: string, pinyin: string, revealedCount: number): string {
  const initials = getInitialLettersByWordAndPinyin(word, pinyin);
  const chars = word.split('');
  const result: string[] = [];

  for (let i = 0; i < chars.length; i++) {
    if (i < revealedCount) {
      result.push(chars[i]);
    } else {
      result.push(initials[i] || '?');
    }
  }

  return result.join(' ');
}

/**
 * 根据提示等级生成提示文本（GameViewModel 调用）
 * 
 * 提示等级语义（根据 PRD F-08）：
 * 以4字成语"龙飞凤舞"（首字母 L F F W）为例：
 * - hintLevel = 0: 显示前2个首字母 "LF"
 * - hintLevel = 1: 显示前3个首字母 "LFF"
 * - hintLevel = 2: 显示所有4个首字母 "LFFW"
 * - hintLevel >= 3: 显示完整答案 "龙飞凤舞"
 * 
 * 通用逻辑：
 * - hintLevel < wordLen - 1: 显示 (hintLevel + 2) 个首字母
 * - hintLevel >= wordLen - 1: 显示完整答案
 * 
 * @param word 完整成语
 * @param hintLevel 提示等级
 * @returns 提示文本
 */
export function generateHint(word: string, hintLevel: number): string {
  const wordLen = word.length;
  const initials = getInitialLetters(word).replace(/ /g, ''); // 去掉空格，如 "LFFW"
  
  // 显示完整答案（hintLevel >= wordLen - 1）
  if (hintLevel >= wordLen - 1) {
    return word;
  }
  
  // 逐步显示首字母：显示前 (hintLevel + 2) 个首字母
  const revealCount = Math.min(hintLevel + 2, wordLen);
  return initials.substring(0, revealCount);
}

/**
 * 根据题库拼音字段生成首字母提示。
 * @param word 完整成语
 * @param pinyin 题库中的完整拼音
 * @param hintLevel 提示等级
 * @returns 提示文本
 */
export function generateHintFromPinyin(word: string, pinyin: string, hintLevel: number): string {
  const wordLen = word.length;
  const initials = getInitialLettersByWordAndPinyin(word, pinyin).join('');

  if (hintLevel >= wordLen - 1) {
    return word;
  }

  const revealCount = Math.min(hintLevel + 2, wordLen);
  return initials.substring(0, revealCount);
}
